# API Oficial - WhatsApp Meta Business API
NODE_ENV=production
PORT=6000

# Banco de Dados PostgreSQL
DATABASE_LINK=postgresql://usuario:senha@localhost:5432/nome_banco

# Token de Administração (gere um token seguro)
TOKEN_ADMIN=seu_token_admin_aqui

# URL do Backend Principal (para WebSocket)
URL_BACKEND_MULT100=https://api.seudominio.com.br

# Redis
REDIS_URI=redis://:senha@127.0.0.1:5000

# RabbitMQ (opcional - desabilitado por padrão)
RABBITMQ_ENABLED_GLOBAL=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672
